<!DOCTYPE html>
<html>


<head>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <link rel="stylesheet" href="	https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">  
  <link rel="stylesheet" href="index.css">
  <link rel="stylesheet" href="home.css">

  <title>Home</title>
</head>

<body>
  <section>
    <nav class="navbar navbar-expand-lg bg-orange navbar-dark fixed-top">
      <div class="container justify-content-center">
        <a href="/" class="navbar-brand">Planny</a>
        <a class="text-light" href="/logout">Logout</a>
      </div>
    </nav>
  </section>

  <section class="pt-5 m-5">
    <div class="container-md border border-dark rounded main shadow">
      <h1 class="mt-5 mb-5">Welcome home <%= user.username %> !</h1>
      <!-- Button to trigger modalAddEvent -->
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAddEvent" data-bs-whatever="@qsdqs">
        Add Event
      </button>

      <!-- Modal modalAddEvent -->
      <div class="modal fade" id="modalAddEvent" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="myModalLabel">Add New Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <!-- Modal Form -->
                <form action = "/addEvent" method="post">
                  
                  <!-- Title -->
                  <div class="form-group" id="Title">
                    <label for="summary" class="col-form-label">Summary:</label>
                    <input type="text" class="form-control" id="summary" name="summary" required value="Event Title">
                  </div>
                  
                  <!-- Recipient Email Address -->
                  <div class="form-group" id="recipient-email-address">
                    <div class="form-group" id="recipient-email-address-1">
                      <label for="recipient-name-${i}" class="col-form-label">Recipient:</label>
                      <input type="text" class="form-control" id="recipient-name-1" name="name" required value ="user1">
                    </div>
                  </div>
                  <button type="button" class ="btn btn-primary mt-3" id="js-add-recipient">Add Recipient</button>
                  
                  <!-- Description -->
                  <div class="form-group">
                    <label for="description" class="col-form-label">Description:</label>
                    <textarea class="form-control" id="description-text" name="description" required>Dectiption</textarea>
                  </div>

                  <!-- Location -->
                  <div class="form-group" id="Location">
                    <label for="location" class="col-form-label">Location:</label>
                    <input type="text" class="form-control" id="summary" name="location" required value="Location">
                  </div>

                  <!-- Date and Time -->
                  <div class="form-group" id="reunions">
                    <div id="reunion-1">
                      <div class="row">
                        <div class="col">
                          <label for="reunion-date-1" class="col-form-label">Date:</label>
                          <input type="date" class="form-control" id="reunion-date-1" name="date" required value="2023-10-01">
                        </div>
                      </div>
                      <div class="row">
                        <div class="col">
                          <label for="reunion-time-start-1" class="col-form-label">Time Start:</label>
                          <input type="time" class="form-control" id="reunion-time-start-1" name="time" required value="12:00">
                        </div>
                        <div class="col">
                          <label for="reunion-time-end-1" class="col-form-label">Time End:</label>
                          <input type="time" class="form-control" id="reunion-time-end-1" name="time" required value="13:00">
                        </div>
                      </div>
                    </div>
                  </div>
                  <button type="button" class ="btn btn-primary mt-3" id="js-add-date">Add Date And Time</button><br>
                  
                  <!-- Submit button -->
                  <button type="submit" data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-block mt-3">Submit</button>
                </form>
              </div>
            </div> 
          </form> 
        </div>
      </div>

      <!-- Dashboard -->
      <div class="container-lg mt-5" id="events-container">
        <div class="row">
          <div class=" col-md pending">
            <h2 class="text-center">Pending Events</h2>
            <div class="pending-events-list"></div>
            <hr>
          </div>
          <div class=" col-md upcoming-events">
            <h2 class="text-center">Upcoming Events</h2>
            <div class="upcoming-events-list"></div>
            <hr>
          </div>
          <div class="col-md past-events">
            <h2 class="text-center">Past Events</h2>
            <div class="past-events-list"></div>
            <hr>
          </div>
        </div>
        
      </div>

      <!-- Modal modalEventDetails -->
      <div class="modal fade" id="modalEventDetails" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered ">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="modalEventDetailsLabel"></h5>
            </div>
            <div class="modal-body" id="modalEventDetailsBody">
              <p id="description"></p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  

  

</body>
<script type ="module" src="/js/eventDetails.js" ></script>
<script type ="module" src="/js/home.js" ></script>
<script src="/js/addEvent.js" ></script>



</html>