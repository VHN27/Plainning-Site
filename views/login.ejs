<!DOCTYPE html>
<html>

<head>
  <link rel="stylesheet" href="	https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">  
  <link rel="stylesheet" href="	https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">  
  <link rel="stylesheet" href="index.css">
  <title>Login</title>
</head>

<body>
  <!-- Navbar -->
   <section>
    <nav class="navbar navbar-expand-lg bg-orange navbar-dark fixed-top">
      <div class="container justify-content-center">
        <a href="/" class="navbar-brand">Planny</a>
      </div>
    </nav>
   </section>
 

  <!-- Login form -->
  <section class="vh-100 border">
    <div class="container d-flex justify-content-center align-items-center h-100 ">
      <form action="/login" method="post" class="border rounded p-5" id="loginLogoutForm">
        <div class="row text-center">
          <div class="col-12"><h1>Login</h1></div>
        </div>
        <div class="row text-center m-3">
          <div class="col-3"><label for="username">Username:</label></div>
          <div class="col-6"><input required type="text" name="username" id="username" value ="" /></div>
        </div>
        <div class="row text-center m-3">
          <div class="col-3"><label for="password">Password:</label></div>
          <div class="col-6"><input required type="password" name="password" id="password" value="" /></div>
        </div>
        <div class="row text-center justify-content-center m-3">
          <input type="submit" class="btn btn-warning w-50 h-25 m-3 " value="Login" />
          <a href="/signup">No account yet ? Sign up !</a>
        </div>
      </form>
    </div>
  </section>
  

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>