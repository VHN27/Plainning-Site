<!DOCTYPE html>
<html>

<head>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <link rel="stylesheet" href="	https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="index.css">
  <link rel="stylesheet" href="home.css">

  <title>Invite</title>
</head>

<body>
  <div class="container">
    <h1>Welcome <%= email %> for event: <%= eventNames %>
    </h1>
    '<div class="alert alert-warning" role="alert">You have been invited to join a party planning app. Click the button
      above to accept the invitation.</div>
    
    <form class="container1" action="/invite-page/accept" method="post">
      <input type="text" name="email" value=<%=email %> required hidden>
      <input type="text" name="eventId" value=<%=eventId %> required hidden>
      <select class="form-select" id='options' name="options" aria-label="Default select example">
      </select>
      <button type="submit" class="btn btn-primary">Accept</button>
    </form>
  </div>


</body>

<script>
  window.eventId = "<%= eventId %>";
</script>
<script type="module" src="../js/invite-page.js"></script>



</html>